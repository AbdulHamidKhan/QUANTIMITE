# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL="postgresql://user:password@localhost:5432/quantimite?schema=public"

# NextAuth / JWT
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
JWT_ACCESS_SECRET="generate-with-openssl-rand-base64-32"
JWT_REFRESH_SECRET="generate-with-openssl-rand-base64-32"

# Object storage (Cloudflare R2 / S3)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="quantimite-uploads"
R2_PUBLIC_HOST=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="no-reply@quantimite.com"

# Search (optional - leave empty for built-in search)
MEILI_HOST=""
MEILI_MASTER_KEY=""

# Allowed CORS origin (your frontend in production)
ALLOWED_ORIGIN="http://localhost:3000"